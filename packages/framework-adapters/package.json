{
  "name": "@agentskit/framework-adapters",
  "version": "0.1.0",
  "description": "Reactivity bindings for AgentsKit ChatController across Vue, Svelte, Solid, React Native, plus a shadcn/ui registry manifest.",
  "keywords": [
    "agentskit",
    "ai",
    "agents",
    "llm",
    "chat",
    "typescript",
    "vue",
    "svelte",
    "solid",
    "react-native",
    "expo",
    "shadcn",
    "composable",
    "hook",
    "store"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./svelte": {
      "types": "./dist/svelte.d.ts",
      "import": "./dist/svelte.js",
      "require": "./dist/svelte.cjs"
    },
    "./solid": {
      "types": "./dist/solid.d.ts",
      "import": "./dist/solid.js",
      "require": "./dist/solid.cjs"
    },
    "./rn": {
      "types": "./dist/rn.d.ts",
      "import": "./dist/rn.js",
      "require": "./dist/rn.cjs"
    },
    "./shadcn/registry.json": "./dist/shadcn/registry.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node ./scripts/copy-registry.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@agentskit/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.4.0",
    "svelte": "^5.0.0",
    "solid-js": "^1.8.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "vue": { "optional": true },
    "svelte": { "optional": true },
    "solid-js": { "optional": true },
    "react": { "optional": true },
    "react-native": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "solid-js": "^1.8.0",
    "svelte": "^5.0.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "vue": "^3.4.0"
  },
  "agentskit": {
    "stability": "alpha",
    "stabilityNote": "Reactivity bindings — API may evolve alongside framework idioms."
  }
}
